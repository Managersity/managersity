{
  "compilerOptions": {
    "target": "ES2017",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "outDir": ".scripts-out",
    "baseUrl": "."
  },
  "include": ["scripts/**/*", "lib/**/*"]
}
